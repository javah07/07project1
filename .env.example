# AeroLine Backend Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# Generate API token:
# python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN=your_generated_token_here

# Base32 TOTP secret
# Must match AeroLine Windows app setting
TOTP_SECRET=your_base32_secret_here

# ProtonVPN credentials
PROTON_USERNAME=your_proton_username
PROTON_PASSWORD=your_proton_password
PROTON_SERVER=IS

# Server settings
HOST=0.0.0.0
PORT=8000

# WireGuard interface
WG_INTERFACE=wg0

# OpenVPN config path
OPENVPN_CONFIG=/etc/openvpn/server.conf

# Client configs directory
CLIENTS_DIR=/etc/openvpn/clients
