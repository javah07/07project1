# ── AeroSky Production Environment ──
# Generate API_TOKEN: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Server & Security ──
HOST=127.0.0.1
PORT=8000
DOMAIN=aerosky.duckdns.org
SERVER_ADDRESS=aerosky.duckdns.org

# ── Auth & JWT ──
# ISSUER must match your public URL
ISSUER=https://aerosky.duckdns.org
AUDIENCE=AeroSky
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=60
API_TOKEN=change_me_now
TOTP_SECRET=change_me_now

# ── Paths ──
# Ensure the app user has write access to these
DB_PATH=/etc/aerosky/aero.db
KEY_DIR=/etc/aerosky/keys

# ── VPN & Networking ──
WG_INTERFACE=wg0
OPENVPN_CONFIG=/etc/openvpn/server.conf
CLIENTS_DIR=/etc/openvpn/clients

# ── ProtonVPN ──
PROTON_USERNAME=
PROTON_PASSWORD=
PROTON_SERVER=IS
