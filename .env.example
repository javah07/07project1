# ═══════════════════════════════════════
# AeroSky Backend Configuration
# Copy to .env and fill in values
# Generate tokens with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════

# API auth token (generate a strong one)
API_TOKEN=change_me_generate_with_secrets

# TOTP secret (must match AeroSky app)
TOTP_SECRET=

# Server binding
# 127.0.0.1 = nginx proxies (production)
# 0.0.0.0 = direct access (dev only)
HOST=127.0.0.1
PORT=8000

# Your DuckDNS domain
DOMAIN=aerosky.duckdns.org
SERVER_ADDRESS=aerosky.duckdns.org

# JWT / OIDC
ISSUER=https://aerosky.duckdns.org
AUDIENCE=AeroLine
JWT_EXPIRE_MINUTES=60

# Database path
DB_PATH=/etc/aerosky/aero.db

# RSA key storage path
KEY_DIR=/etc/aerosky/keys

# ProtonVPN (if using)
PROTON_USERNAME=
PROTON_PASSWORD=
PROTON_SERVER=IS

# WireGuard interface
WG_INTERFACE=wg0

# OpenVPN paths
OPENVPN_CONFIG=/etc/openvpn/server.conf
CLIENTS_DIR=/etc/openvpn/clients
