# AeroLine Backend Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# ── JWT / OIDC ──
# MUST be set to your Railway deployment URL
# e.g. https://aeroline.up.railway.app
ISSUER=https://aerosky.duckdns.org
AUDIENCE=AeroSky
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=60

# ── Database ──
DB_PATH=/data/aero.db

# ── Legacy API Token (deprecated) ──
API_TOKEN=

# ── TOTP secret for authenticator app ──
TOTP_SECRET=

# ── ProtonVPN credentials ──
PROTON_USERNAME=
PROTON_PASSWORD=
PROTON_SERVER=IS

# ── Server settings ──
HOST=0.0.0.0
PORT=8000

# ── WireGuard interface ──
WG_INTERFACE=wg0

# ── OpenVPN config path ──
OPENVPN_CONFIG=/etc/openvpn/server.conf

# ── Client configs directory ──
CLIENTS_DIR=/etc/openvpn/clients
